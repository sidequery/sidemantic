# name: test/sql/sidemantic.test
# description: Test sidemantic semantic layer extension
# group: [sidemantic]

require sidemantic

# Test loading models
statement ok
SELECT * FROM sidemantic_load('
models:
  - name: orders
    table: orders
    primary_key: order_id
    dimensions:
      - name: status
        type: categorical
    metrics:
      - name: revenue
        agg: sum
        sql: amount
      - name: order_count
        agg: count
');

# Test listing models
query I
SELECT * FROM sidemantic_models();
----
orders

# Test manual rewrite function - should contain SUM
query I
SELECT sidemantic_rewrite_sql('SELECT orders.revenue FROM orders') LIKE '%SUM%';
----
true

# Test manual rewrite function - should contain GROUP BY when dimension present
query I
SELECT sidemantic_rewrite_sql('SELECT orders.revenue, orders.status FROM orders') LIKE '%GROUP BY%';
----
true

# Create test table
statement ok
CREATE TABLE orders (order_id INT, status VARCHAR, amount DECIMAL(10,2));

statement ok
INSERT INTO orders VALUES (1, 'completed', 100.00), (2, 'completed', 50.00), (3, 'pending', 75.00);

# Test SEMANTIC keyword query - revenue by status
query IR
SEMANTIC SELECT orders.status, orders.revenue FROM orders ORDER BY orders.status;
----
completed	150.00
pending	75.00

# Test SEMANTIC keyword query - total revenue (no dimensions)
query R
SEMANTIC SELECT orders.revenue FROM orders;
----
225.00

# Test no-prefix semantic query - revenue by status
query IR
SELECT orders.status, orders.revenue FROM orders ORDER BY orders.status;
----
completed	150.00
pending	75.00

# Test no-prefix semantic query - total revenue (no dimensions)
query R
SELECT orders.revenue FROM orders;
----
225.00

# Test ordinary DuckDB SELECT still falls through
query ITR
SELECT * FROM orders ORDER BY order_id;
----
1	completed	100.00
2	completed	50.00
3	pending	75.00

# Test loading Cube.js format
statement ok
SELECT * FROM sidemantic_load('
cubes:
  - name: products
    sql_table: products
    dimensions:
      - name: category
        sql: "${CUBE}.category"
        type: string
    measures:
      - name: total_price
        sql: "${CUBE}.price"
        type: sum
');

# Verify both models are loaded
query I rowsort
SELECT * FROM sidemantic_models();
----
orders
products

# Test no-prefix CREATE METRIC/DIMENSION syntax
statement ok
CREATE MODEL test_model (table orders, primary_key order_id);

statement ok
CREATE OR REPLACE MODEL test_model (name 'test_model', table orders, primary_key order_id);

statement ok
CREATE METRIC test_sum AS SUM(amount);

statement ok
CREATE DIMENSION test_dim AS status;

statement ok
CREATE SEGMENT completed AS status = 'completed';

# Test legacy SEMANTIC prefix remains supported
statement ok
SEMANTIC CREATE MODEL semantic_prefix_model (table orders, primary_key order_id);

statement error
CREATE MODEL mismatched_model (name other_model, table orders, primary_key order_id);
----
CREATE MODEL name 'mismatched_model' does not match body name 'other_model'

statement error
CREATE MODEL mismatched_quoted_model (name 'other_quoted_model', table orders, primary_key order_id);
----
CREATE MODEL name 'mismatched_quoted_model' does not match body name 'other_quoted_model'

statement error
CREATE MODEL mismatched_colon_model (name: other_colon_model, table orders, primary_key order_id);
----
CREATE MODEL name 'mismatched_colon_model' does not match body name 'other_colon_model'

statement error
CREATE MODEL mismatched_equals_model (name=other_equals_model, table orders, primary_key order_id);
----
CREATE MODEL name 'mismatched_equals_model' does not match body name 'other_equals_model'

# Verify test_model is loaded
query I rowsort
SELECT * FROM sidemantic_models();
----
orders
products
semantic_prefix_model
test_model

statement ok
CREATE MODEL nested_props_model (metadata {owner analytics, name internal}, table orders, primary_key order_id);

query I
SELECT count(*) FROM sidemantic_models() WHERE model_name = 'nested_props_model';
----
1

# Test native SQL block definitions through the parser extension
statement ok
MODEL (name block_orders, table orders, primary_key order_id);

statement ok
DIMENSION (name status, type categorical);

statement ok
METRIC (name block_revenue, agg sum, sql amount);

statement ok
METRIC block_order_count AS COUNT(*);

query IR
SELECT block_orders.status, block_orders.block_revenue FROM block_orders ORDER BY block_orders.status;
----
completed	150.00
pending	75.00

query I
SELECT block_orders.block_order_count FROM block_orders;
----
3

# Test compact native SQL model block through the parser extension
statement ok
model compact_orders from orders (
  primary key (order_id)
  status
  sum(amount) as compact_revenue
  count(*) as compact_order_count
);

query IR
SELECT compact_orders.status, compact_orders.compact_revenue FROM compact_orders ORDER BY compact_orders.status;
----
completed	150.00
pending	75.00

query I
SELECT compact_orders.compact_order_count FROM compact_orders;
----
3

# Test repeated YAML load replaces same-name model instead of failing on duplicates
statement ok
SELECT * FROM sidemantic_load('
models:
  - name: reloadable
    table: orders
    primary_key: order_id
    metrics:
      - name: order_count
        agg: count
');

statement ok
SELECT * FROM sidemantic_load('
models:
  - name: reloadable
    table: orders
    primary_key: order_id
    dimensions:
      - name: status
        type: categorical
    metrics:
      - name: revenue
        agg: sum
        sql: amount
');

query R
SEMANTIC SELECT reloadable.revenue FROM reloadable;
----
225.00

# Test no-prefix MODEL active-model switching and repeated use/rewrite sequence
statement ok
CREATE MODEL sql_orders (table orders, primary_key order_id);

statement ok
CREATE METRIC sql_revenue AS SUM(amount);

statement ok
CREATE DIMENSION status AS status;

query IR
SEMANTIC SELECT sql_orders.status, sql_orders.sql_revenue FROM sql_orders ORDER BY sql_orders.status;
----
completed	150.00
pending	75.00

statement ok
CREATE OR REPLACE MODEL sql_orders (name sql_orders, table orders, primary_key order_id);

statement ok
MODEL sql_orders;

statement ok
CREATE OR REPLACE METRIC sql_order_count AS COUNT(*);

query I
SEMANTIC SELECT sql_orders.sql_order_count FROM sql_orders;
----
3
