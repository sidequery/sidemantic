guid: "model-wrapped-join-key"
export_schema_version: "2"
model:
  name: users_model
  description: Join keys wrapped in LOWER() are not plain equality keys
  model_tables:
    - name: users
      fqn: ANALYTICS.PUBLIC.users
      joins:
        - with: contacts
          on: "LOWER([users::email]) = LOWER([contacts::email])"
          type: LEFT_OUTER
          cardinality: MANY_TO_ONE
    - name: contacts
      fqn: ANALYTICS.PUBLIC.contacts
  columns:
    - name: user_id
      column_id: users::id
      properties:
        column_type: ATTRIBUTE
    - name: contact_name
      column_id: contacts::name
      properties:
        column_type: ATTRIBUTE
    - name: amount
      column_id: users::amount
      properties:
        column_type: MEASURE
        aggregation: SUM
