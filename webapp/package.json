{
  "name": "sidemantic-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Embeddable analytics UI for the Sidemantic semantic layer (works against the Python or Rust backend over the shared HTTP contract).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4322",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:unit": "bun test src"
  },
  "dependencies": {
    "apache-arrow": "^17.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
